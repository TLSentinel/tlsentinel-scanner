TLSENTINEL_API_URL=http://localhost:8080
TLSENTINEL_API_TOKEN=scanner_<token-from-api>

# Optional. Hard local ceiling on per-cycle scan concurrency (default 64).
# Clamps the server-supplied value so a misconfigured or compromised server
# cannot push the scanner past what the host can handle without exhausting
# file descriptors or goroutines. A warning is logged whenever clamping
# actually happens.
# TLSENTINEL_SCANNER_MAX_CONCURRENCY=64
